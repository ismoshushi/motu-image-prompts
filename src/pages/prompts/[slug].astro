---
import Layout from '../../layouts/Layout.astro';
import dataset from '../../../data/prompts.json';

export function getStaticPaths() {
  return dataset.prompts.map((prompt) => ({ params: { slug: prompt.slug }, props: { prompt } }));
}
const { prompt } = Astro.props;
const title = prompt.titleZh || prompt.titleEn;
const description = prompt.promptZh || prompt.promptEn;
const showSource = !prompt.hideSource && !prompt.id?.startsWith('case-');
---
<Layout title={`${title} | Motu Image Prompts`} description={description.slice(0, 150)}>
  <article class="detail wrap">
    <a class="back" href="/">← 返回提示词库</a>
    <div class="detail-head">
      {prompt.imageUrl && <img src={prompt.imageUrl} alt={prompt.imageAltZh || prompt.imageAltEn || title} referrerpolicy="no-referrer" />}
      <div>
        <p class="eyebrow">{prompt.categoryLabelZh} · {prompt.categoryLabelEn}</p>
        <h1>{title}</h1>
        {prompt.titleZh && prompt.titleEn && <p class="title-en">{prompt.titleEn}</p>}
        <div class="tags">{[...prompt.styles, ...prompt.scenes].map((tag) => <span>{tag}</span>)}</div>
      </div>
    </div>
    {prompt.promptZh && <section class="prompt-block">
      <div class="block-title">
        <h2>中文提示词</h2>
        <div class="block-actions">
          <button data-copy="zh">复制</button>
          <a href="https://gen.moshushi.xyz/" target="_blank" rel="noopener" data-generate="zh">去生成</a>
        </div>
      </div>
      <pre id="prompt-zh">{prompt.promptZh}</pre>
    </section>}
    {prompt.promptEn && <section class="prompt-block">
      <div class="block-title">
        <h2>English prompt</h2>
        <div class="block-actions">
          <button data-copy="en">Copy</button>
          <a href="https://gen.moshushi.xyz/" target="_blank" rel="noopener" data-generate="en">去生成</a>
        </div>
      </div>
      <pre id="prompt-en">{prompt.promptEn}</pre>
    </section>}
    {showSource && prompt.attribution && <p class="source">归属：{prompt.attribution}</p>}
    {showSource && prompt.externalSourceUrl && <p class="source">外部来源：<a href={prompt.externalSourceUrl} rel="noopener">{prompt.externalSourceLabel || prompt.externalSourceUrl}</a></p>}
    {showSource && <p class="source">收录来源：<a href={prompt.sourceUrlZh || prompt.sourceUrlEn} rel="noopener">{prompt.sourceUrlZh || prompt.sourceUrlEn}</a></p>}
  </article>
  <div id="copy-toast" class="copy-toast" role="status" aria-live="polite">提示词已复制</div>
  <script>
    const copyPrompt = async (language) => {
      const id = language === 'zh' ? '#prompt-zh' : '#prompt-en';
      await navigator.clipboard.writeText(document.querySelector(id).textContent);
    };

    for (const button of document.querySelectorAll('[data-copy]')) {
      button.addEventListener('click', async () => {
        await copyPrompt(button.dataset.copy);
        const original = button.textContent;
        button.textContent = '已复制';
        setTimeout(() => button.textContent = original, 1200);
      });
    }

    const toast = document.querySelector('#copy-toast');
    let toastTimer;
    for (const link of document.querySelectorAll('[data-generate]')) {
      link.addEventListener('click', async () => {
        await copyPrompt(link.dataset.generate);
        toast.classList.add('show');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => toast.classList.remove('show'), 1800);
      });
    }
  </script>
</Layout>
